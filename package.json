{
  "name": "coco-framework",
  "version": "1.2.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.2.0",
  "keywords": ["ai-agent", "bnb-chain", "web3", "typescript", "llm"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm lint && pnpm test && pnpm typecheck",
    "lint": "biome check .",
    "release:check": "pnpm check && pnpm build && pnpm release:pack",
    "release:pack": "node scripts/release-pack.mjs",
    "test": "vitest run --coverage",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.5",
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "^3.0.7",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  },
  "pnpm": {
    "ignoredBuiltDependencies": ["@biomejs/biome", "esbuild"],
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
