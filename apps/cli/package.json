{
  "name": "@coco/cli",
  "version": "1.2.0",
  "description": "CLI for Coco Framework chat and server workflows.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "coco": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm build",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
